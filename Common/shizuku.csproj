<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>disable</Nullable>

    <LangVersion>9</LangVersion>

    <!-- Unity側からエラーが出るので適当に指定しておく -->
    <OutputPath>$(MSBuildProjectDirectory)\.csproj\bin\</OutputPath>
    <BaseIntermediateOutputPath>$(MSBuildProjectDirectory)\.csproj\obj\</BaseIntermediateOutputPath>
  </PropertyGroup>

  <ItemGroup>
	  <None Update="**\\**.meta" Visible="false" />
  </ItemGroup>
</Project>
